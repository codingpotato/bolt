# Dependencies
node_modules/

# Build output
dist/

# Runtime data — ephemeral state that must NOT be committed
.bolt/sessions/
.bolt/memory/
.bolt/corrupted/
.bolt/tasks.json
.bolt/tool-audit.jsonl
.bolt/bolt.log

# The following .bolt/ entries ARE committed (project configuration):
#   .bolt/AGENT.md      — project-level agent prompt
#   .bolt/config.json   — project config (no credentials)
#   .bolt/skills/       — custom skill overrides
#   .bolt/workflows/    — ComfyUI workflow configs (site-specific, must be edited by user)

# Environment
.env
.env.local

# Coverage
coverage/

# OS
.DS_Store

# Claude Code — personal settings (project settings.json is committed)
.claude/settings.local.json

workspace
