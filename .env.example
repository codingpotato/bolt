# =============================================================================
# bolt — Environment Variables
# =============================================================================
# Copy this file to .env and uncomment the variables you need.
# All values are optional except authentication (one of the three modes below).
# bolt works with zero configuration — only auth is required to start.
#
# Precedence: .env values > .bolt/config.json > built-in defaults
# =============================================================================

# ── Authentication (required — set exactly ONE of the following three) ───────

# Option 1: Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Anthropic subscription session token (Claude.ai)
# ANTHROPIC_SESSION_TOKEN=...

# Option 3: Local Anthropic-compatible server (Ollama, llama.cpp, etc.)
# BOLT_LOCAL_ENDPOINT=http://localhost:8080
# BOLT_LOCAL_API_KEY=                          # only if your local server requires one

# ── Core ─────────────────────────────────────────────────────────────────────

# Model ID (applies to all auth modes)
# BOLT_MODEL=claude-opus-4-6

# Workspace root — absolute path where bolt can read/write files
# Default: process.cwd() (the directory where bolt is invoked)
# BOLT_WORKSPACE_ROOT=/path/to/my/project

# Runtime data directory (relative to workspace root if not absolute)
# BOLT_DATA_DIR=.bolt

# Log verbosity: debug | info | warn | error
# Default: info — info + warn + error written to .bolt/bolt.log
# BOLT_LOG_LEVEL=info

# Real-time LLM payload tracing — pretty colored blocks on stderr
# Includes: system prompts, full messages, tool inputs/outputs, sub-agent payloads
# WARNING: may contain sensitive data. Use only for debugging.
# BOLT_LOG_TRACE=false

# ── Web Search ───────────────────────────────────────────────────────────────

# Search provider: searxng (default, free) | brave | serper
# BOLT_SEARCH_PROVIDER=searxng

# Endpoint URL for the search provider
# SearXNG: http://localhost:8080
# Brave: https://api.search.brave.com (uses BOLT_SEARCH_API_KEY)
# Serper: https://google.serper.dev (uses BOLT_SEARCH_API_KEY)
# BOLT_SEARCH_ENDPOINT=http://localhost:8080

# API key for Brave or Serper (not needed for SearXNG)
# BOLT_SEARCH_API_KEY=...

# Default max results per search
# BOLT_SEARCH_MAX_RESULTS=10

# ── ComfyUI (Image & Video Generation) ───────────────────────────────────────

# Comma-separated ComfyUI server URLs (enables comfyui_text2img/img2video tools)
# BOLT_COMFYUI_SERVERS=http://gpu1:8188,http://gpu2:8188

# Workflow names (without .json) — resolved from .bolt/workflows/ first, then built-in
# BOLT_COMFYUI_TEXT2IMG_WORKFLOW=image_z_image_turbo
# BOLT_COMFYUI_IMG2VIDEO_WORKFLOW=video_ltx2_3_i2v

# Polling interval for generation completion (ms)
# BOLT_COMFYUI_POLL_INTERVAL_MS=2000

# Max wait per generation before timeout (ms)
# BOLT_COMFYUI_TIMEOUT_MS=300000

# Max simultaneous jobs per server
# BOLT_COMFYUI_MAX_CONCURRENT=2

# Note: Server weights, advanced workflow settings → .bolt/config.json

# ── WebChannel (Browser/Phone Access) ────────────────────────────────────────

# Enable WebChannel HTTP/WebSocket server
# BOLT_WEB_ENABLED=true

# Authentication token (required for remote access)
# BOLT_WEB_TOKEN=your-secret-token

# Server bind host
# BOLT_WEB_HOST=0.0.0.0

# Server port
# BOLT_WEB_PORT=3000

# Connection mode: websocket | http
# BOLT_WEB_MODE=websocket

# ── FFmpeg (Video Post-Production) ──────────────────────────────────────────

# Explicit path to ffmpeg binary (resolved via system PATH if omitted)
# BOLT_FFMPEG_PATH=/usr/local/bin/ffmpeg

# ── Memory System ────────────────────────────────────────────────────────────

# Fraction of context window that triggers compaction (0.0–1.0)
# BOLT_MEMORY_COMPACT_THRESHOLD=0.8

# Number of recent messages always retained after compaction
# BOLT_MEMORY_KEEP_RECENT=10

# Search backend for memory_search: keyword | embedding
# BOLT_MEMORY_SEARCH_BACKEND=keyword

# ── Agent Prompt ─────────────────────────────────────────────────────────────

# Path to project-level AGENT.md
# BOLT_AGENT_PROJECT_FILE=.bolt/AGENT.md

# Path to user-level AGENT.md
# BOLT_AGENT_USER_FILE=~/.bolt/AGENT.md

# ── Tasks & Tools ────────────────────────────────────────────────────────────

# Max depth for nested subtasks
# BOLT_TASKS_MAX_SUBTASK_DEPTH=5

# Max retries for a failed task
# BOLT_TASKS_MAX_RETRIES=3

# Timeout per tool call (ms, 0 = no timeout)
# BOLT_TOOLS_TIMEOUT_MS=30000

# Global tool allowlist — comma-separated (omit to allow all)
# BOLT_TOOLS_ALLOWED=bash,file_read,file_write,web_search,comfyui_text2img

# ── Code Workflows ───────────────────────────────────────────────────────────

# Max retries during automated test fix attempts
# BOLT_CODE_TEST_FIX_RETRIES=3

# ── CLI Output ───────────────────────────────────────────────────────────────

# Show progress events in TTY mode
# BOLT_CLI_PROGRESS=true

# Show progress events even in non-TTY mode (e.g. CI)
# BOLT_CLI_VERBOSE=false
