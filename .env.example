# Authentication — set exactly one of the following three:

# Option 1: Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Anthropic subscription session token
# ANTHROPIC_SESSION_TOKEN=...

# Option 3: Local Anthropic-compatible server
# BOLT_LOCAL_ENDPOINT=http://localhost:8080
# BOLT_LOCAL_API_KEY=   # only if your local server requires one

# Model (applies to all auth modes)
# BOLT_MODEL=claude-opus-4-6

# Discord integration (optional)
# DISCORD_BOT_TOKEN=...
# DISCORD_CHANNEL_ID=...

# Runtime
# BOLT_DATA_DIR=.bolt
# BOLT_LOG_LEVEL=info
