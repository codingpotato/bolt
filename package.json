{
  "name": "bolt",
  "version": "0.1.0",
  "description": "Autonomous AI CLI agent built with TypeScript and the Anthropic SDK",
  "type": "commonjs",
  "main": "dist/cli/index.js",
  "bin": {
    "bolt": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/cli/index.ts",
    "dev:watch": "tsx watch --env-file=.env src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
