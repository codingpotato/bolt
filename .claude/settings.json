{
  "permissions": {
    "deny": [
      "Bash(git push origin main*)",
      "Bash(git push origin master*)"
    ],
    "ask": [
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/enforce-branch.sh",
            "statusMessage": "Checking branch policy..."
          }
        ]
      }
    ]
  }
}
